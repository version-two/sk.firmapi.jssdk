{
  "name": "firmapi",
  "version": "1.0.0",
  "description": "Official JavaScript/TypeScript SDK for FirmAPI - Slovak Company Data API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "firmapi",
    "api",
    "sdk",
    "slovak",
    "companies",
    "orsr",
    "business-register",
    "typescript"
  ],
  "author": "Version Two <info@versiontwo.sk>",
  "license": "MIT",
  "homepage": "https://firmapi.sk",
  "repository": {
    "type": "git",
    "url": "https://github.com/firmapi/sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/firmapi/sdk-js/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
